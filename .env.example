# Copy to .env and fill in. .env is gitignored — never commit real secrets.
ANTHROPIC_API_KEY=sk-ant-...
GMAIL_ADDRESS=you@gmail.com
# Gmail App Password = 16 lowercase letters, NO spaces (needs 2-Step Verification ON)
GMAIL_APP_PASSWORD=abcdefghijklmnop
# Optional; defaults to GMAIL_ADDRESS
DIGEST_TO=you@gmail.com
# Optional model override
# DIGEST_MODEL=claude-sonnet-4-6
# Transcript provider (local bgutil PO-token server); default shown
POT_BASE_URL=http://127.0.0.1:4416
