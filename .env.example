# Copy to .env and fill in. .env is gitignored — never commit real secrets.
ANTHROPIC_API_KEY=sk-ant-...

# --- Email (works with ANY IMAP/SMTP provider: Gmail, Outlook, Yahoo, Fastmail, iCloud, ...) ---
EMAIL_ADDRESS=you@example.com
# An APP PASSWORD for your email (not your normal login). How to get one varies by provider:
#   Gmail/Yahoo/Fastmail/iCloud: create an "app password" (usually needs 2FA on).
#   Outlook/Microsoft 365: app passwords may be disabled; you may need OAuth instead — ask your agent.
EMAIL_PASSWORD=your-app-password
# Optional; defaults to EMAIL_ADDRESS
DIGEST_TO=you@example.com

# Mail server hosts. Defaults are Gmail — CHANGE THESE if you use another provider:
#   Outlook:  IMAP_HOST=outlook.office365.com   SMTP_HOST=smtp.office365.com   SMTP_PORT=587
#   Yahoo:    IMAP_HOST=imap.mail.yahoo.com     SMTP_HOST=smtp.mail.yahoo.com  SMTP_PORT=465
#   Fastmail: IMAP_HOST=imap.fastmail.com       SMTP_HOST=smtp.fastmail.com    SMTP_PORT=465
#   iCloud:   IMAP_HOST=imap.mail.me.com        SMTP_HOST=smtp.mail.me.com     SMTP_PORT=587
IMAP_HOST=imap.gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# How processed newsletters are deduped:
#   seen  = mark read + remember the message id (SAFE on every provider; default)
#   gmail = archive by removing from INBOX (Gmail ONLY — would DELETE on most others)
ARCHIVE_MODE=seen

# Optional model + transcript provider
# DIGEST_MODEL=claude-sonnet-4-6
POT_BASE_URL=http://127.0.0.1:4416
