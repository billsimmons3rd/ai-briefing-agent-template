<?xml version="1.0" encoding="UTF-8"?>
<!-- Weekly NEWSLETTER brief: Mondays 7am. Replace <ABSOLUTE-PATH-TO-REPO>. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>aibrief.newsletter</string>
  <key>ProgramArguments</key>
  <array>
    <string><ABSOLUTE-PATH-TO-REPO>/run_digest.sh</string>
    <string>--no-videos</string><string>--label</string><string>newsletters</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict><key>Weekday</key><integer>1</integer><key>Hour</key><integer>7</integer><key>Minute</key><integer>0</integer></dict>
  <key>StandardOutPath</key><string><ABSOLUTE-PATH-TO-REPO>/state/launchd.out</string>
  <key>StandardErrorPath</key><string><ABSOLUTE-PATH-TO-REPO>/state/launchd.err</string>
</dict></plist>
